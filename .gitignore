# Virtual environments
backend/venv/
backend/.venv/
backend/env/
backend/.env/

# Python bytecode cache
**/__pycache__/
**/*.py[cod]
**/*.pyo

# Distribution / packaging
backend/*.egg-info/
backend/dist/
backend/build/
backend/.eggs/

# Environment variables
backend/.env
backend/.env.local
backend/.env.*.local

# pytest / coverage
backend/.pytest_cache/
backend/htmlcov/
backend/.coverage
backend/coverage.xml

# mypy / pyright type checker
backend/.mypy_cache/
backend/.dmypy.json
backend/pyrightconfig.json


